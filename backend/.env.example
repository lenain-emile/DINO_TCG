#  (DO NOT commit .env)

# Server port
PORT=3000

# Database (Supabase ou local Postgres) / a modifier avec vos propres credentials (j'utilise Supabase pour le dev local et la prod)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Auth (generer des secrets avec `openssl rand -base64 32`)
#
# Générer 2 secrets (recommandé, portable) :
#   node -e "const c=require('crypto'); console.log('JWT_SECRET='+c.randomBytes(32).toString('hex')); console.log('REFRESH_TOKEN_SECRET='+c.randomBytes(32).toString('hex'));"
#
# Alternative OpenSSL (à faire 2 fois) :
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME
REFRESH_TOKEN_SECRET=CHANGE_ME

# Options
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_DAYS=30
BCRYPT_SALT_ROUNDS=12
